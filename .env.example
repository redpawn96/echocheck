# API
APP_ENV=development
APP_NAME=EchoCheck API
API_PORT=8000
DATABASE_URL=postgresql+psycopg://echocheck:echocheck@localhost:5432/echocheck
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Worker
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Providers
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
